# ── Serial Connection ──────────────────────────────────────────────
# Use /dev/serial/by-id/... for a stable path that survives reboots
# Run: ls /dev/serial/by-id/ to find yours
SERIAL_PORT=/dev/ttyUSB0
BAUD_RATE=115200
POLL_INTERVAL=10

# ── Ports ──────────────────────────────────────────────────────────
MONITOR_PORT=8080     # Web UI + API
METRICS_PORT=9812     # Prometheus metrics
PROMETHEUS_PORT=9090  # Prometheus UI
GRAFANA_PORT=3000     # Grafana UI

# ── Grafana ────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=solar

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
